# =============================
# Ente self-host environment
# Copy this file to .env and replace placeholder values.
# Never commit real secrets.
# =============================

# Web app origin for API requests (served by ghcr.io/ente-io/web)
# Example: https://api.example.com
ENTE_API_ORIGIN=https://api.example.com

# -----------------------------
# Postgres
# -----------------------------
# Database superuser/app user name
POSTGRES_USER=pguser
# Strong database password
POSTGRES_PASSWORD=change-me-very-strong-password
# Database name used by museum
POSTGRES_DB=ente_db

# -----------------------------
# MinIO
# -----------------------------
# MinIO root user (access key)
MINIO_ROOT_USER=minio-admin
# MinIO root password (secret key)
MINIO_ROOT_PASSWORD=change-me-minio-root-password

# -----------------------------
# Museum database connection
# -----------------------------
# Hostname of postgres service in compose network
MUSEUM_DB_HOST=postgres
# Postgres port
MUSEUM_DB_PORT=5432
# Database name museum should connect to
MUSEUM_DB_NAME=ente_db
# Database username museum should connect with
MUSEUM_DB_USER=pguser
# Database password museum should connect with
MUSEUM_DB_PASSWORD=change-me-very-strong-password

# -----------------------------
# S3 credentials used by museum.yaml
# -----------------------------
# Access key for object storage (MinIO or external S3-compatible provider)
S3_ACCESS_KEY=minio-admin
# Secret key for object storage
S3_SECRET_KEY=change-me-minio-root-password

# -----------------------------
# Museum cryptographic secrets
# -----------------------------
# Base64 key used for data encryption
# Generate a long random base64 string.
MUSEUM_KEY_ENCRYPTION=replace-with-random-base64-encryption-key
# Base64 key used for hashing/key derivation
# Generate a long random base64 string.
MUSEUM_KEY_HASH=replace-with-random-base64-hash-key
# JWT signing secret for museum auth tokens
# Generate a long random base64 string.
MUSEUM_JWT_SECRET=replace-with-random-base64-jwt-secret

# -----------------------------
# SMTP (email delivery)
# -----------------------------
# SMTP server host
SMTP_HOST=smtp.example.com
# SMTP server port (commonly 587 for STARTTLS, 465 for SMTPS)
SMTP_PORT=587
# SMTP username/login
SMTP_USERNAME=user@example.com
# SMTP password or app password
SMTP_PASSWORD=change-me-smtp-password
# Sender email address shown in outbound emails
SMTP_EMAIL=noreply@example.com

# -----------------------------
# Object storage endpoint
# -----------------------------
# HTTPS endpoint for S3-compatible storage used by museum
# Example: https://s3.example.com
S3_ENDPOINT=https://s3.example.com

# -----------------------------
# Public app URLs (used by museum for links and redirects)
# -----------------------------
# Public albums app URL
ENTE_PUBLIC_ALBUMS_URL=https://albums.example.com
# Cast app URL
ENTE_CAST_URL=https://cast.example.com
# Locker/share app URL
ENTE_PUBLIC_LOCKER_URL=https://locker.example.com
# Paste app URL
ENTE_PUBLIC_PASTE_URL=https://paste.example.com
# Embedded albums app URL
ENTE_EMBED_ALBUMS_URL=https://embed.example.com
# Accounts app URL
ENTE_ACCOUNTS_URL=https://accounts.example.com

# -----------------------------
# WebAuthn
# -----------------------------
# Relying Party ID (usually the accounts domain without scheme)
WEBAUTHN_RPID=accounts.example.com
# Allowed WebAuthn origin (must include https://)
WEBAUTHN_RPORIGIN=https://accounts.example.com